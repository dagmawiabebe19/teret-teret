# =============================================================================
# Teret-Teret environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (app/lib/supabase/client.ts, server.ts, admin.ts)
# Get from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Anthropic - story generation (app/api/generate-story/route.ts, server-only)
# Get from: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Optional: use AI for illustration prompts (default: local/deterministic)
# AI_ILLUSTRATION_PROMPTS=true

# -----------------------------------------------------------------------------
# Stripe - subscriptions (app/api/create-checkout-session, stripe/*, config)
# Get from: https://dashboard.stripe.com/apikeys and Products/Prices
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# App URL - used for Stripe success/cancel/portal redirects (app/api/stripe/*, create-checkout-session)
# Set to production URL in production (e.g. https://teret.vercel.app)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
